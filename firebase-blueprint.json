{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "A customer in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the customer" },
        "name": { "type": "string", "description": "Full name of the customer" },
        "email": { "type": "string", "format": "email", "description": "Email address of the customer" },
        "phone": { "type": "string", "description": "Phone number of the customer" },
        "address": { "type": "string", "description": "Physical address of the customer" },
        "photo": { "type": "string", "description": "Base64 encoded photo or URL" },
        "type": { "type": "string", "enum": ["Regular", "Premium", "Wholesale"], "description": "Customer type" },
        "totalOrders": { "type": "number", "description": "Total number of orders placed" },
        "totalDue": { "type": "number", "description": "Current outstanding balance" },
        "lastPurchase": { "type": "string", "format": "date", "description": "Date of last purchase" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the customer was created" }
      },
      "required": ["name", "phone"]
    }
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers"
    }
  }
}
